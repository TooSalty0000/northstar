{
  "name": "@northstar/app",
  "version": "0.1.3",
  "private": true,
  "description": "Northstar — local-first accomplishment tracker",
  "author": "TooSalty0000",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist:builder": "electron-builder --config electron-builder.yml --publish never"
  },
  "comment": "All UI/runtime deps are bundled by electron-vite/vite, and the sidecar ships its own deps via extraResources — so the packaged app has NO runtime node_modules. Everything lives in devDependencies so electron-builder packages nothing from node_modules.",
  "devDependencies": {
    "@northstar/shared": "*",
    "@tanstack/react-query": "^5.62.7",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "canvas-confetti": "^1.9.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "motion": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "vite": "^5.4.11",
    "zustand": "^5.0.2"
  }
}
